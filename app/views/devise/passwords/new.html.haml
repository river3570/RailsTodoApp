.container
  .auth-form
    %h2.auth-form__title パスワードをお忘れですか？
    = form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post }) do |f|
      = render "devise/shared/error_messages", resource: resource
      .auth-form__field
        = f.label :email, "メールアドレス", class: "auth-form__label"
        = f.email_field :email, autofocus: true, autocomplete: "email", class: "auth-form__input"
      .auth-form__actions
        = f.submit "パスワード再設定のメールを送る", class: "auth-form__submit"
    = render "devise/shared/links"
