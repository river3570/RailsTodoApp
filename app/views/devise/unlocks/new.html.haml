.container
  .auth-form
    %h2.auth-form__title アカウントロック解除メールの再送
    = form_for(resource, as: resource_name, url: unlock_path(resource_name), html: { method: :post }) do |f|
      = render "devise/shared/error_messages", resource: resource
      .auth-form__field
        = f.label :email, "メールアドレス", class: "auth-form__label"
        = f.email_field :email, autofocus: true, autocomplete: "email", class: "auth-form__input"
      .auth-form__actions
        = f.submit "ロック解除メールを再送する", class: "auth-form__submit"
    = render "devise/shared/links"
