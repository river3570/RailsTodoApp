.container
  .auth-form
    %h2.auth-form__title ログイン
    = form_for(resource, as: resource_name, url: session_path(resource_name)) do |f|
      .auth-form__field
        = f.label :email, "メールアドレス", class: "auth-form__label"
        = f.email_field :email, autofocus: true, autocomplete: "email", class: "auth-form__input"
      .auth-form__field
        = f.label :password, "パスワード", class: "auth-form__label"
        = f.password_field :password, autocomplete: "current-password", class: "auth-form__input"
      - if devise_mapping.rememberable?
        .auth-form__field.auth-form__field--checkbox
          = f.check_box :remember_me, class: "auth-form__checkbox"
          = f.label :remember_me, "ログイン状態を保持する", class: "auth-form__checkbox-label"
      .auth-form__actions
        = f.submit "ログイン", class: "auth-form__submit"
    = render "devise/shared/links"
