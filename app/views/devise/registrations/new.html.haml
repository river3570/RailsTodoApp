.container
  .auth-form
    %h2.auth-form__title 新規登録
    = form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f|
      = render "devise/shared/error_messages", resource: resource
      .auth-form__field
        = f.label :email, "メールアドレス", class: "auth-form__label"
        = f.email_field :email, autofocus: true, autocomplete: "email", class: "auth-form__input"
      .auth-form__field
        = f.label :password, "パスワード", class: "auth-form__label"
        - if @minimum_password_length
          %span.auth-form__hint= "（#{@minimum_password_length}文字以上）"
        = f.password_field :password, autocomplete: "new-password", class: "auth-form__input"
      .auth-form__field
        = f.label :password_confirmation, "パスワード（確認）", class: "auth-form__label"
        = f.password_field :password_confirmation, autocomplete: "new-password", class: "auth-form__input"
      .auth-form__actions
        = f.submit "登録する", class: "auth-form__submit"
    = render "devise/shared/links"
