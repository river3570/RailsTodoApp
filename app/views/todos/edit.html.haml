.container
  .todo-form
    %h2.todo-form__title Todo編集
    = form_with model: @todo, local: true do |f|
      - if @todo.errors.any?
        .todo-form__errors
          %ul
            - @todo.errors.full_messages.each do |msg|
              %li= msg
      .todo-form__field
        = f.label :title, "タイトル", class: "todo-form__label"
        = f.text_field :title, class: "todo-form__input", placeholder: "2〜20文字で入力してください"
      .todo-form__field
        = f.label :context, "内容", class: "todo-form__label"
        = f.text_area :context, class: "todo-form__textarea", placeholder: "2〜300文字で入力してください", rows: 5
      .todo-form__field
        %span.todo-form__label ステータス
        .todo-form__radio-group
          = f.label :completed_false, class: "todo-form__radio-label" do
            = f.radio_button :completed, false, class: "todo-form__radio"
            未完了
          = f.label :completed_true, class: "todo-form__radio-label" do
            = f.radio_button :completed, true, class: "todo-form__radio"
            完了
      .todo-form__actions
        = link_to "キャンセル", todos_path, class: "todo-form__cancel"
        = f.submit "更新する", class: "todo-form__submit"
