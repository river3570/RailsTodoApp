.container
  .todo-form
    %h2.todo-form__title Todo新規作成
    = form_with model: @todo, local: true do |f|
      - if @todo.errors.any?
        .todo-form__errors
          %ul
            - @todo.errors.full_messages.each do |msg|
              %li= msg
      .todo-form__field
        = f.label :title, "タイトル", class: "todo-form__label"
        = f.text_field :title, class: "todo-form__input", placeholder: "2〜20文字で入力してください"
      .todo-form__field
        = f.label :context, "内容", class: "todo-form__label"
        = f.text_area :context, class: "todo-form__textarea", placeholder: "2〜300文字で入力してください", rows: 5
      .todo-form__actions
        = f.submit "作成する", class: "todo-form__submit"
        = link_to "キャンセル", todos_path, class: "todo-form__cancel"
